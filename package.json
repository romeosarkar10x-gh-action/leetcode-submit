{
    "name": "leetcode-submit",
    "version": "0.0.0",
    "description": "Submit LeetCode solutions from CI using a session token and metadata",
    "author": "Romeo Sarkar",
    "license": "ISC",
    "scripts": {
        "build": "node esbuild.ts",
        "test": "echo \"Error: no test specified\" && exit 1",
        "format:check": "prettier \"**/*.{ts,json,yml,yaml,md}\" --check --debug-check --ignore-path .prettierignore",
        "format": "prettier \"**/*.{ts,json,yml,yaml,md}\" --write --ignore-path .prettierignore",
        "lint": "eslint --flag unstable_native_nodejs_ts_config .",
        "type-check": "tsc -p tsconfig.json"
    },
    "keywords": [
        "github",
        "actions",
        "github-actions",
        "gha"
    ],
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.3.0",
            "onFail": "download"
        }
    },
    "type": "module",
    "devDependencies": {
        "esbuild": "^0.28.1",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1"
    }
}
